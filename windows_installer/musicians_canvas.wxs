<?xml version="1.0" encoding="UTF-8"?>
<!--
    WiX 4 source file for the Musician's Canvas Windows installer.
    See installer/README.md for build instructions and a feature overview.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package Name="Musician's Canvas"
           Manufacturer="Eric Oulashin"
           Version="$(var.Version)"
           UpgradeCode="b7e5f2a8-8c4d-4f1e-9b2a-3d4e5f6a7b8c"
           Scope="perMachine"
           InstallerVersion="500">

    <SummaryInformation Description="Musician's Canvas multi-track music recording application"
                        Manufacturer="Eric Oulashin"/>

    <MajorUpgrade DowngradeErrorMessage="A newer version of Musician's Canvas is already installed."/>
    <MediaTemplate EmbedCab="yes"/>

    <Icon Id="MusiciansCanvasIcon" SourceFile="$(var.StagingDir)\musicians_canvas.exe"/>
    <Property Id="ARPPRODUCTICON" Value="MusiciansCanvasIcon"/>
    <Property Id="ARPHELPLINK" Value="https://github.com/EricOulashin/musicians_canvas"/>
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/EricOulashin/musicians_canvas"/>

    <!-- Install location: C:\Program Files\Musicians_Canvas -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Musicians_Canvas"/>
    </StandardDirectory>

    <!-- Start Menu folder structure: "Musician's Canvas" with a "Docs" subfolder -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="Musician's Canvas">
        <Directory Id="DocsFolder" Name="Docs"/>
      </Directory>
    </StandardDirectory>

    <Feature Id="Main" Title="Musician's Canvas" Level="1">
      <ComponentGroupRef Id="HarvestedFiles"/>
      <ComponentRef Id="MainShortcuts"/>
      <ComponentRef Id="DocsShortcuts"/>
    </Feature>

  </Package>

  <!-- Harvest every file under the staging directory and install it
       to INSTALLFOLDER, preserving the relative subdirectory structure. -->
  <Fragment>
    <ComponentGroup Id="HarvestedFiles" Directory="INSTALLFOLDER">
      <Files Include="$(var.StagingDir)\**"/>
    </ComponentGroup>
  </Fragment>

  <!-- Main Start Menu shortcuts (the two executables) -->
  <Fragment>
    <Component Id="MainShortcuts" Directory="ApplicationProgramsFolder">
      <Shortcut Id="MusiciansCanvasSC"
                Name="Musician's Canvas"
                Description="Multi-track music recording"
                Target="[INSTALLFOLDER]musicians_canvas.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="MusiciansCanvasIcon"/>
      <Shortcut Id="VirtualMidiKeyboardSC"
                Name="Virtual MIDI Keyboard"
                Description="On-screen virtual MIDI keyboard"
                Target="[INSTALLFOLDER]virtual_midi_keyboard.exe"
                WorkingDirectory="INSTALLFOLDER"/>
      <RemoveFolder Id="RemoveAppMenuFolder"
                    Directory="ApplicationProgramsFolder"
                    On="uninstall"/>
      <RegistryValue Root="HKCU"
                     Key="Software\EricOulashin\MusiciansCanvas"
                     Name="installed"
                     Type="integer"
                     Value="1"
                     KeyPath="yes"/>
    </Component>
  </Fragment>

  <!-- Documentation shortcuts: HTML and PDF user manuals in all 18 languages -->
  <Fragment>
    <Component Id="DocsShortcuts" Directory="DocsFolder">

      <!-- English -->
      <Shortcut Id="UMenHTML" Name="User Manual - English (HTML)"
                Target="[INSTALLFOLDER]docs\html\MusiciansCanvas_User_Manual.html"/>
      <Shortcut Id="UMenPDF" Name="User Manual - English (PDF)"
                Target="[INSTALLFOLDER]docs\MusiciansCanvas_User_Manual.pdf"/>

      <!-- German -->
      <Shortcut Id="UMdeHTML" Name="User Manual - Deutsch (HTML)"
                Target="[INSTALLFOLDER]docs\html\MusiciansCanvas_User_Manual_de.html"/>
      <Shortcut Id="UMdePDF" Name="User Manual - Deutsch (PDF)"
                Target="[INSTALLFOLDER]docs\MusiciansCanvas_User_Manual_de.pdf"/>

      <!-- Spanish -->
      <Shortcut Id="UMesHTML" Name="User Manual - Espanol (HTML)"
                Target="[INSTALLFOLDER]docs\html\MusiciansCanvas_User_Manual_es.html"/>
      <Shortcut Id="UMesPDF" Name="User Manual - Espanol (PDF)"
                Target="[INSTALLFOLDER]docs\MusiciansCanvas_User_Manual_es.pdf"/>

      <!-- French -->
      <Shortcut Id="UMfrHTML" Name="User Manual - Francais (HTML)"
                Target="[INSTALLFOLDER]docs\html\MusiciansCanvas_User_Manual_fr.html"/>
      <Shortcut Id="UMfrPDF" Name="User Manual - Francais (PDF)"
                Target="[INSTALLFOLDER]docs\MusiciansCanvas_User_Manual_fr.pdf"/>

      <!-- Japanese -->
      <Shortcut Id="UMjaHTML" Name="User Manual - Japanese (HTML)"
                Target="[INSTALLFOLDER]docs\html\MusiciansCanvas_User_Manual_ja.html"/>
      <Shortcut Id="UMjaPDF" Name="User Manual - Japanese (PDF)"
                Target="[INSTALLFOLDER]docs\MusiciansCanvas_User_Manual_ja.pdf"/>

      <!-- Portuguese (Brazil) -->
      <Shortcut Id="UMptbrHTML" Name="User Manual - Portugues BR (HTML)"
                Target="[INSTALLFOLDER]docs\html\MusiciansCanvas_User_Manual_pt-BR.html"/>
      <Shortcut Id="UMptbrPDF" Name="User Manual - Portugues BR (PDF)"
                Target="[INSTALLFOLDER]docs\MusiciansCanvas_User_Manual_pt-BR.pdf"/>

      <!-- Traditional Chinese -->
      <Shortcut Id="UMzhtwHTML" Name="User Manual - Chinese Traditional (HTML)"
                Target="[INSTALLFOLDER]docs\html\MusiciansCanvas_User_Manual_zh-TW.html"/>
      <Shortcut Id="UMzhtwPDF" Name="User Manual - Chinese Traditional (PDF)"
                Target="[INSTALLFOLDER]docs\MusiciansCanvas_User_Manual_zh-TW.pdf"/>

      <!-- Simplified Chinese -->
      <Shortcut Id="UMzhcnHTML" Name="User Manual - Chinese Simplified (HTML)"
                Target="[INSTALLFOLDER]docs\html\MusiciansCanvas_User_Manual_zh-CN.html"/>
      <Shortcut Id="UMzhcnPDF" Name="User Manual - Chinese Simplified (PDF)"
                Target="[INSTALLFOLDER]docs\MusiciansCanvas_User_Manual_zh-CN.pdf"/>

      <!-- Russian -->
      <Shortcut Id="UMruHTML" Name="User Manual - Russian (HTML)"
                Target="[INSTALLFOLDER]docs\html\MusiciansCanvas_User_Manual_ru.html"/>
      <Shortcut Id="UMruPDF" Name="User Manual - Russian (PDF)"
                Target="[INSTALLFOLDER]docs\MusiciansCanvas_User_Manual_ru.pdf"/>

      <!-- Swedish -->
      <Shortcut Id="UMsvHTML" Name="User Manual - Svenska (HTML)"
                Target="[INSTALLFOLDER]docs\html\MusiciansCanvas_User_Manual_sv.html"/>
      <Shortcut Id="UMsvPDF" Name="User Manual - Svenska (PDF)"
                Target="[INSTALLFOLDER]docs\MusiciansCanvas_User_Manual_sv.pdf"/>

      <!-- Finnish -->
      <Shortcut Id="UMfiHTML" Name="User Manual - Suomi (HTML)"
                Target="[INSTALLFOLDER]docs\html\MusiciansCanvas_User_Manual_fi.html"/>
      <Shortcut Id="UMfiPDF" Name="User Manual - Suomi (PDF)"
                Target="[INSTALLFOLDER]docs\MusiciansCanvas_User_Manual_fi.pdf"/>

      <!-- Danish -->
      <Shortcut Id="UMdaHTML" Name="User Manual - Dansk (HTML)"
                Target="[INSTALLFOLDER]docs\html\MusiciansCanvas_User_Manual_da.html"/>
      <Shortcut Id="UMdaPDF" Name="User Manual - Dansk (PDF)"
                Target="[INSTALLFOLDER]docs\MusiciansCanvas_User_Manual_da.pdf"/>

      <!-- Norwegian -->
      <Shortcut Id="UMnbHTML" Name="User Manual - Norsk (HTML)"
                Target="[INSTALLFOLDER]docs\html\MusiciansCanvas_User_Manual_nb.html"/>
      <Shortcut Id="UMnbPDF" Name="User Manual - Norsk (PDF)"
                Target="[INSTALLFOLDER]docs\MusiciansCanvas_User_Manual_nb.pdf"/>

      <!-- Polish -->
      <Shortcut Id="UMplHTML" Name="User Manual - Polski (HTML)"
                Target="[INSTALLFOLDER]docs\html\MusiciansCanvas_User_Manual_pl.html"/>
      <Shortcut Id="UMplPDF" Name="User Manual - Polski (PDF)"
                Target="[INSTALLFOLDER]docs\MusiciansCanvas_User_Manual_pl.pdf"/>

      <!-- Greek -->
      <Shortcut Id="UMelHTML" Name="User Manual - Greek (HTML)"
                Target="[INSTALLFOLDER]docs\html\MusiciansCanvas_User_Manual_el.html"/>
      <Shortcut Id="UMelPDF" Name="User Manual - Greek (PDF)"
                Target="[INSTALLFOLDER]docs\MusiciansCanvas_User_Manual_el.pdf"/>

      <!-- Irish -->
      <Shortcut Id="UMgaHTML" Name="User Manual - Gaeilge (HTML)"
                Target="[INSTALLFOLDER]docs\html\MusiciansCanvas_User_Manual_ga.html"/>
      <Shortcut Id="UMgaPDF" Name="User Manual - Gaeilge (PDF)"
                Target="[INSTALLFOLDER]docs\MusiciansCanvas_User_Manual_ga.pdf"/>

      <!-- Welsh -->
      <Shortcut Id="UMcyHTML" Name="User Manual - Cymraeg (HTML)"
                Target="[INSTALLFOLDER]docs\html\MusiciansCanvas_User_Manual_cy.html"/>
      <Shortcut Id="UMcyPDF" Name="User Manual - Cymraeg (PDF)"
                Target="[INSTALLFOLDER]docs\MusiciansCanvas_User_Manual_cy.pdf"/>

      <!-- Pirate -->
      <Shortcut Id="UMpirateHTML" Name="User Manual - Pirate (HTML)"
                Target="[INSTALLFOLDER]docs\html\MusiciansCanvas_User_Manual_pirate.html"/>
      <Shortcut Id="UMpiratePDF" Name="User Manual - Pirate (PDF)"
                Target="[INSTALLFOLDER]docs\MusiciansCanvas_User_Manual_pirate.pdf"/>

      <RemoveFolder Id="RemoveDocsMenuFolder"
                    Directory="DocsFolder"
                    On="uninstall"/>
      <RegistryValue Root="HKCU"
                     Key="Software\EricOulashin\MusiciansCanvas"
                     Name="docs_installed"
                     Type="integer"
                     Value="1"
                     KeyPath="yes"/>
    </Component>
  </Fragment>

</Wix>
